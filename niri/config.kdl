// ============================================================
//  config.kdl — Niri (Protocolo de Estabilidade Máxima)
// ============================================================

input {
    keyboard {
        xkb {
            layout "us"
        }
        repeat-delay 200
        repeat-rate 35
    }
    mouse {
        accel-speed -0.5
    }
    focus-follows-mouse
}

output "HDMI-A-2" {
    mode "1920x1080@60.000"
    scale 1.0
    transform "normal"
}

environment {
    XCURSOR_THEME "Adwaita"
    XCURSOR_SIZE "27"
    QT_QPA_PLATFORMTHEME "qt6ct"
    QT_QPA_PLATFORM "wayland;xcb"
    GDK_BACKEND "wayland,x11,*"
    XDG_CURRENT_DESKTOP "niri"
    XDG_SESSION_TYPE "wayland"
    XDG_SESSION_DESKTOP "niri"
    MOZ_ENABLE_WAYLAND "1"
    ELECTRON_OZONE_PLATFORM_HINT "auto"
}

spawn-at-startup "waybar"
spawn-at-startup "/usr/lib/polkit-kde-authentication-agent-1"
spawn-at-startup "udiskie"
spawn-at-startup "sh" "-c" "wl-paste --type text --watch cliphist store"
spawn-at-startup "sh" "-c" "wl-paste --type image --watch cliphist store"
spawn-at-startup "sh" "-c" "cliphist wipe"
spawn-at-startup "sh" "-c" "awww-daemon --format xrgb && sleep 1 && awww img /home/flix/dotfiles/wallpapers/full-Black.jpg"
spawn-at-startup "sh" "-c" "hyprctl setcursor Adwaita 27"

layout {
    gaps 10
    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }
    default-column-width { proportion 0.5; }
    focus-ring {
        width 3
        active-color "#B0B8C0"
        inactive-color "#0D0D10"
    }
    border {
        off
        width 3
        active-color "#B0B8C0"
        inactive-color "#0D0D10"
    }
    shadow {
        off
    }
}

prefer-no-csd
screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

window-rule {
    match app-id=r#"firefox$"# title="^Picture-in-Picture$"
    open-floating true
}
binds {
    Mod+Shift+Slash { show-hotkey-overlay; }

    // Aplicações
    Mod+T { spawn "kitty"; }
    Mod+Space { spawn "anyrun"; }
    Mod+Shift+Z { spawn "zen-browser"; }
    Mod+Y { spawn "kitty" "-e" "yazi"; }
    Menu { spawn "sh" "-c" "kitty nvim"; }
    Mod+Shift+O { spawn "obsidian"; }

    // Colunas e Janelas
    Mod+Comma  { consume-window-into-column; }
    Mod+Period { expel-window-from-column; }

    // Navegação e Movimento (HJKL)
    Mod+H { focus-column-left; }
    Mod+J { focus-window-down; }
    Mod+K { focus-window-up; }
    Mod+L { focus-column-right; }
    
    Mod+Ctrl+H { move-column-left; }
    Mod+Ctrl+J { move-window-down; }
    Mod+Ctrl+K { move-window-up; }
    Mod+Ctrl+L { move-column-right; }

    // Mouse e Scroll
    Mod+WheelScrollDown       { focus-column-right; }
    Mod+WheelScrollUp         { focus-column-left; }
    Mod+Shift+WheelScrollDown { focus-window-down; }
    Mod+Shift+WheelScrollUp   { focus-window-up; }

    // Sistema
    F1 { spawn "systemctl" "hibernate"; }
    End { spawn "systemctl" "poweroff"; }
    Ctrl+Grave { spawn "sh" "-c" "killall waybar || waybar"; }
    Alt+V { spawn "sh" "-c" "cliphist list | anyrun --plugins /etc/anyrun/plugins/libstdin.so | cliphist decode | wl-copy"; }

    // Screenshots
    Print { spawn "sh" "-c" "grim -g \"$(slurp)\" ~/Imagens/$(date +%Y-%m-%d_%H-%M-%S).png && wl-copy < ~/Imagens/$(date +%Y-%m-%d_%H-%m-%S).png"; }
    Mod+Print { spawn "sh" "-c" "grim ~/Pictures/$(date +%Y-%m-%d_%H-%m-%S).png && wl-copy < ~/Pictures/$(date +%Y-%m-%d_%H-%m-%S).png"; }

    // Audio - Protocolo de Compatibilidade Total
    // Teclas de Função (Fallback)
    F7  allow-when-locked=true { spawn "sh" "-c" "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"; }
    F8  allow-when-locked=true { spawn "sh" "-c" "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.05-"; }
    F9  allow-when-locked=true { spawn "sh" "-c" "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.05+ -l 1.0"; }

    // Símbolos Multimídia
    XF86AudioRaiseVolume allow-when-locked=true { spawn "sh" "-c" "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.05+ -l 1.0"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn "sh" "-c" "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.05-"; }
    XF86AudioMute        allow-when-locked=true { spawn "sh" "-c" "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"; }

    // Workspaces
    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }

    Mod+Shift+1 { move-column-to-workspace 1; }
    Mod+Shift+2 { move-column-to-workspace 2; }
    Mod+Shift+3 { move-column-to-workspace 3; }
    Mod+Shift+4 { move-column-to-workspace 4; }

    // Gestão de Janelas
    Alt+F4       { close-window; }
    Mod+F        { maximize-column; }
    Mod+Shift+F  { fullscreen-window; }
    Mod+V        { toggle-window-floating; }
    Mod+C        { center-column; }
    Mod+Minus    { set-column-width "-10%"; }
    Mod+Equal    { set-column-width "+10%"; }
    
    Mod+O repeat=false { toggle-overview; }
    Mod+Shift+E  { quit; }
    Mod+Escape { toggle-keyboard-shortcuts-inhibit; }
}
